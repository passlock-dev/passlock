// typedoc.json
{
  "$schema": "https://typedoc.org/schema.json",
  "name": "@passlock/server",
  "entryPoints": ["src/safe.ts", "src/index.ts"],
  "plugin": ["typedoc-plugin-markdown"],
  "outputs": [
    {
      "name": "html",
      "path": "./docs/api"
    },
    {
      "name": "html",
      "path": "../../../private/packages/public-api-docs/public/server/"
    },
    {
      "name": "markdown",
      "path": "./docs/llms-api"
    },
    {
      "name": "markdown",
      "path": "../../../private/packages/public-api-docs/public/llms/server/"
    }
  ],
  "navigation": {
    "includeCategories": true,
    "includeGroups": true,
    "excludeReferences": false,
    "includeFolders": true
  },
  "categorizeByGroup": false,
  "readme": "none",
  "cleanOutputDir": true,
  "categoryOrder": ["Passkeys", "Principal", "Authentication", "*"],
  "groupOrder": ["Functions", "Interfaces", "Classes", "*"],
  "sort": ["kind", "instance-first", "source-order"],
  "navigationLinks": {
    "📖 Main Site": "https://passlock.dev"
  },
  "sidebarLinks": {
    "@passlock/browser": "https://apidocs.passlock.dev/browser/index.html"
  },
  "hostedBaseUrl": "https://apidocs.passlock.dev/server/",
  "includeVersion": true
}
