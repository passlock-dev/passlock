{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": true,

    // Emission
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    "stripInternal": true, // hide @internal from .d.ts
    "newLine": "lf",

    // usually you don't want tests or dev-only types leaking into build
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "test/**/*",
    "dist",
    "node_modules"
  ]
}
