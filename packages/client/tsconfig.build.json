{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* Projects */
    "composite": true,

    /* Output */
    "rootDir": "./src",
    "outDir": "./dist",
    "stripInternal": true,
    "noEmitOnError": true,

    // library-friendly defaults (adjust to your setup)
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "test/**/*",
    "dist",
    "node_modules"
  ]
}
