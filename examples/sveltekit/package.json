{
	"name": "@passlock/sveltekit-example",
	"description": "SvelteKit app making full use of passkeys along with email based one time login codes",
	"private": true,
	"version": "2.3.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"db:push": "drizzle-kit push --force",
		"reset": "vite-node --options.transformMode.ssr='/.*/' src/reset.ts",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "prettier --write . && eslint --fix .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@clack/prompts": "^1.1.0",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@lucide/svelte": "^1.7.0",
		"@passlock/client": "^2.3.1",
		"@passlock/server": "^2.3.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25",
		"daisyui": "^5.5.19",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.1",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"sveltekit-superforms": "^2.30.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"valibot": "^1.3.1",
		"vite": "^8.0.3",
		"vite-node": "^6.0.0"
	},
	"dependencies": {
		"@libsql/client": "^0.17.2"
	}
}
